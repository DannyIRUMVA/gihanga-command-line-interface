  "entitlementFlow": [
    "User selects Upskillsafrica AI in model/provider selection.",
    "Gihanga checks local/backend entitlement status.",
    "If missing or expired, Gihanga asks for Rwanda mobile money phone number and starts Paypack cash-in through the payment Worker.",
    "Gihanga polls /subscription/verify/{transactionRef} until payment is processed, cancelled, or times out.",
    "When verified as processed/successful, backend stores an entitlement receipt and enables Upskillsafrica AI model access.",
    "For monthly plan, backend tracks gpt-5 daily usage and resets quota each UTC day.",
    "Organisation models require x-upskillsafrica-org-code or organisationCode in the request body."
  ],
  "securityNotes": [
    "Do not store Paypack client credentials in Gihanga CLI.",
    "Do not store Azure or OpenRouter API keys in Gihanga CLI or Git.",
    "Azure model keys and OpenRouter keys must stay in backend Worker secrets.",
    "Organisation code must stay in backend Worker secrets.",
    "The payment Worker must verify webhooks before granting server-side access."
